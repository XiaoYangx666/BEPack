{
    "name": "bepack",
    "version": "0.0.1",
    "description": "A modern pack builder for Minecraft Bedrock Edition.",
    "keywords": [
        "minecraft",
        "bedrock",
        "addon",
        "script-api",
        "mcpack",
        "mcaddon",
        "build-tool"
    ],
    "license": "MIT",
    "author": "XiaoYangx666",
    "type": "module",
    "packageManager": "npm@11.18.0",
    "sideEffects": false,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "README.zh-CN.md",
        "reference.md",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "bin": {
        "bepack": "dist/cli.js"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
        "build": "npm run clean && rolldown -c && node scripts/chmod.mjs",
        "check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier ./src --write",
        "format:check": "prettier ./src --check"
    },
    "dependencies": {
        "cac": "^7.0.0",
        "chokidar": "^5.0.0",
        "fflate": "^0.8.3",
        "picocolors": "^1.1.1",
        "rolldown": "^1.1.4"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "prettier": "^3.6.2",
        "rolldown-plugin-dts": "^0.27.6",
        "typescript": "7.0.2",
        "vitest": "^4.1.10"
    }
}
